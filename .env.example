# ---- Lockstep core configuration (12-factor) ----
# Same file shape for managed cloud and self-host; only values differ.

# Server
PORT=8080
NODE_ENV=development
# Public base URL of the core API (the CLI/MCP/Action talk to this)
LOCKSTEP_API_URL=http://localhost:8080

# Postgres (the single system-of-record)
DATABASE_URL=postgres://lockstep:lockstep@localhost:5432/lockstep
# App connects as a restricted, append-only-aware role (see migrations)
DATABASE_APP_ROLE=lockstep_app

# Secret used to sign/verify Lockstep session tokens (opaque tokens are hashed, this signs metadata)
TOKEN_SIGNING_SECRET=dev-only-change-me

# ---- GitHub App ----
# Managed cloud: our App. Self-host: the customer registers THEIR OWN App and fills these in.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=      # required for the dashboard "Sign in with GitHub" (web OAuth exchange)
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Register the dashboard's OAuth callback on the GitHub App: <dashboard-url>/login/github/callback

# ---- Dashboard (web) ----
# The dashboard's own public URL — used to build the GitHub OAuth redirect_uri (must match the
# callback registered on the App). Auto-derived from proxy headers if unset; set explicitly on Railway.
LOCKSTEP_WEB_URL=

# ---- Outbound (urgent pings) ----
SLACK_BOT_TOKEN=

# ---- Dev-mode login bypass ----
# Enables /auth/dev-login (no GitHub App needed). Never honored when NODE_ENV=production.
LOCKSTEP_DEV_LOGIN=1

# ---- Deployment mode ----
# "cloud" = multi-tenant SaaS; "self-host" = typically single-org
LOCKSTEP_DEPLOYMENT=self-host
