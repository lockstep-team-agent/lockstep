{
  "name": "lockstep-cli",
  "version": "0.1.0",
  "description": "Keep your team's AI coding agents in lockstep — shared decisions, contracts, ownership and dependencies across repos.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/lockstep-team-agent/lockstep",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lockstep-team-agent/lockstep.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lockstep-team-agent/lockstep/issues"
  },
  "keywords": [
    "lockstep",
    "mcp",
    "claude-code",
    "codex",
    "ai-agents",
    "coordination",
    "codeowners"
  ],
  "bin": {
    "lockstep": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "test": "find src -name '*.test.ts' | xargs node --import tsx --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
